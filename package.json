{
  "name": "padelstats",
  "private": true,
  "version": "0.1.0",
  "description": "PadelStats packaging shell for web + iOS + Android via Capacitor.",
  "scripts": {
    "serve": "python3 -m http.server 4173",
    "build:mobile": "node ./scripts/prepare-mobile-shell.mjs",
    "cap:sync": "npm run build:mobile && npx cap sync",
    "cap:copy": "npm run build:mobile && npx cap copy",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/core": "^7.4.2",
    "@supabase/supabase-js": "^2.100.1"
  },
  "devDependencies": {
    "@capacitor/android": "^7.4.2",
    "@capacitor/cli": "^7.4.2",
    "@capacitor/ios": "^7.4.2"
  }
}
